APP_ENV=local
APP_URL=http://localhost:8000
APP_KEY=troque-esta-chave-por-uma-chave-segura
JWT_TTL=3600

# Origens permitidas para o front (separadas por vírgula). Se vazio, usa * (qualquer origem).
# Ex.: CORS_ORIGINS=http://localhost:8082,http://localhost:5173,https://seu-front.vercel.app
# CORS_ORIGINS=

# Supabase Postgres (opcao 1: usar Supabase como banco)
# Exemplo:
# DB_DSN=pgsql:host=db.<project-ref>.supabase.co;port=5432;dbname=postgres;sslmode=require
DB_DSN=pgsql:host=db.seu-project-ref.supabase.co;port=5432;dbname=postgres;sslmode=require
DB_USER=postgres
DB_PASS=sua-senha-do-banco
